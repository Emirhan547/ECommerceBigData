@model ECommerceBigData.Models.DashboardViewModel
@{
    string TrendClass(decimal value) => value >= 0 ? "text-emerald-400" : "text-rose-400";
    string TrendIcon(decimal value) => value >= 0 ? "trending_up" : "trending_down";
}

<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <article class="panel p-5">
        <p class="text-zinc-500 text-xs uppercase">Toplam Sipariş</p>
        <h4 class="text-xl font-bold">@Model.EntityOverview.OrderCount.ToString("N0")</h4>
        <a href="/Orders" class="text-xs text-sky-400 hover:text-sky-300">Siparişleri görüntüle →</a>
    </article>
    <article class="panel p-5">
        <p class="text-zinc-500 text-xs uppercase">Sipariş Detayı</p>
        <h4 class="text-xl font-bold">@Model.EntityOverview.OrderDetailCount.ToString("N0")</h4>
        <a href="/OrderDetails" class="text-xs text-sky-400 hover:text-sky-300">Sipariş Detayları görüntüle →</a>
    </article>
    <article class="panel p-5">
        <p class="text-zinc-500 text-xs uppercase">Müşteri Sayısı</p>
        <h4 class="text-xl font-bold">@Model.EntityOverview.CustomerCount.ToString("N0")</h4>
        <a href="/Customers" class="text-xs text-sky-400 hover:text-sky-300">Müşterileri görüntüle →</a>
    </article>
    <article class="panel p-5">
        <p class="text-zinc-500 text-xs uppercase">Toplam Ciro</p>
        <h4 class="text-2xl font-bold">@Model.Summary.TotalRevenue.ToString("C0")</h4>
        <p class="text-xs @TrendClass(Model.RevenueGrowthRate)"><span class="material-symbols-outlined text-sm align-middle">@TrendIcon(Model.RevenueGrowthRate)</span> @Model.RevenueGrowthRate.ToString("F1")% önceki döneme göre</p>
    </article>
    


</section>