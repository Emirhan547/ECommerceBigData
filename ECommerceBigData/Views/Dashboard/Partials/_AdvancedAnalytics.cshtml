@model ECommerceBigData.Models.DashboardViewModel

<section class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <article class="panel p-5 lg:col-span-7">
        <h3 class="font-bold mb-2">Monthly Revenue & Order Count (12M)</h3>
        <canvas id="monthlyRevenueChart" height="130"></canvas>
    </article>
    <article class="panel p-5 lg:col-span-5">
        <h3 class="font-bold mb-3">Order Intensity Heatmap (3M)</h3>
        <div id="hourlyHeatmap" class="grid grid-cols-12 gap-1"></div>
        <p class="text-[11px] text-zinc-500 mt-3">Y-axis: weekday, X-axis: hour blocks.</p>
    </article>
</section>

<section class="panel p-5">
    <div class="flex justify-between items-center mb-3">
        <h3 class="font-bold">Top Customers by Lifetime Value</h3>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-zinc-500 text-xs uppercase border-b border-zinc-800">
                    <th class="py-2 text-left">Customer</th>
                    <th class="py-2 text-left">Location</th>
                    <th class="py-2 text-right">Orders</th>
                    <th class="py-2 text-right">LTV</th>
                    <th class="py-2 text-right">Segment</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.TopCustomers.Any())
                {
                    foreach (var customer in Model.TopCustomers)
                    {
                        <tr class="border-b border-zinc-900">
                            <td class="py-2">@customer.FullName</td>
                            <td class="py-2">@customer.City, @customer.Country</td>
                            <td class="py-2 text-right">@customer.TotalOrders</td>
                            <td class="py-2 text-right">@customer.LifetimeValue.ToString("C2")</td>
                            <td class="py-2 text-right">@customer.Segment</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td class="py-4 text-zinc-500" colspan="5">No customer records for selected filters.</td></tr>
                }
            </tbody>
        </table>
    </div>
</section>