@model ECommerceBigData.Models.DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Archive Admin | Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed-variant": "#004c6e",
                        "on-secondary-fixed": "#002113",
                        "on-secondary-container": "#00311f",
                        "secondary-fixed-dim": "#4edea3",
                        "error-container": "#93000a",
                        "primary-fixed": "#c9e6ff",
                        "on-tertiary-container": "#4d2b00",
                        "on-surface": "#e5e2e1",
                        "on-secondary": "#003824",
                        "surface-container-high": "#2a2a2a",
                        "on-tertiary": "#492900",
                        "surface-variant": "#353534",
                        "on-error-container": "#ffdad6",
                        "on-primary-fixed": "#001e2f",
                        "tertiary-container": "#de8712",
                        "inverse-on-surface": "#313030",
                        "surface-bright": "#393939",
                        "outline-variant": "#3e4850",
                        "surface-dim": "#131313",
                        "inverse-surface": "#e5e2e1",
                        "surface-container": "#201f1f",
                        "on-tertiary-fixed-variant": "#693c00",
                        "on-primary": "#00344d",
                        "surface-tint": "#89ceff",
                        "on-secondary-fixed-variant": "#005236",
                        "on-background": "#e5e2e1",
                        "inverse-primary": "#006591",
                        "tertiary-fixed-dim": "#ffb86e",
                        "secondary-fixed": "#6ffbbe",
                        "error": "#ffb4ab",
                        "on-surface-variant": "#bec8d2",
                        "tertiary": "#ffb86e",
                        "surface-container-lowest": "#0e0e0e",
                        "on-tertiary-fixed": "#2c1600",
                        "background": "#131313",
                        "on-primary-container": "#003751",
                        "surface": "#131313",
                        "surface-container-highest": "#353534",
                        "surface-container-low": "#1c1b1b",
                        "on-error": "#690005",
                        "secondary": "#4edea3",
                        "tertiary-fixed": "#ffdcbd",
                        "outline": "#88929b",
                        "primary": "#89ceff",
                        "secondary-container": "#00a572",
                        "primary-container": "#0ea5e9",
                        "primary-fixed-dim": "#89ceff"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
            background-color: #131313;
            color: #e5e2e1;
            font-family: 'Inter', sans-serif;
        }

        .glass-card {
            background: rgba(32, 31, 31, 0.6);
            backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="font-body selection:bg-primary selection:text-on-primary">

    <!-- Sidebar Navigation -->
    <aside class="h-screen w-64 fixed left-0 top-0 bg-[#1c1b1b] flex flex-col p-4 space-y-2 z-40 hidden md:flex">
        <div class="px-2 py-6 mb-4">
            <h1 class="text-lg font-extrabold text-white font-headline tracking-tight">Archive Admin</h1>
            <p class="text-xs text-zinc-500 font-medium uppercase tracking-widest">Premium Tier</p>
        </div>
        <nav class="flex-1 space-y-1">
            <a class="flex items-center gap-3 px-4 py-3 bg-sky-500/10 text-sky-400 font-semibold rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-headline text-sm">Dashboard</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-300 hover:bg-[#2a2a2a] rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">shopping_cart</span>
                <span class="font-headline text-sm">Orders</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-300 hover:bg-[#2a2a2a] rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">inventory_2</span>
                <span class="font-headline text-sm">Products</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-300 hover:bg-[#2a2a2a] rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">group</span>
                <span class="font-headline text-sm">Customers</span>
            </a>
        </nav>
        <div class="pt-4 mt-4 space-y-1 border-t border-white/5">
            <button class="w-full flex items-center justify-center gap-2 bg-primary text-on-primary font-bold py-3 px-4 rounded-xl text-sm mb-6 transition-transform active:scale-95">
                <span class="material-symbols-outlined text-sm">add</span>
                Add New Product
            </button>
            <a class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-300 hover:bg-[#2a2a2a] rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">help</span>
                <span class="font-headline text-sm">Support</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-300 hover:bg-[#2a2a2a] rounded-lg transition-all" href="#">
                <span class="material-symbols-outlined">logout</span>
                <span class="font-headline text-sm">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="md:ml-64 flex flex-col min-h-screen">
        <!-- Top Bar -->
        <header class="sticky top-0 z-50 flex items-center justify-between px-6 py-4 w-full bg-[#131313]">
            <div class="flex items-center gap-8 flex-1">
                <h2 class="text-xl font-bold text-white tracking-tighter font-headline md:hidden">Luminous</h2>
                <div class="relative max-w-md w-full hidden md:block">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-lg">search</span>
                    <input class="w-full bg-surface-container-highest border-none text-on-surface text-sm rounded-xl pl-10 pr-4 py-2.5 focus:ring-1 focus:ring-primary/40 placeholder:text-zinc-500" placeholder="Search orders, SKU, or customers..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-4">
                <button class="p-2 text-zinc-400 hover:bg-zinc-800/50 transition-colors rounded-full">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button class="p-2 text-zinc-400 hover:bg-zinc-800/50 transition-colors rounded-full">
                    <span class="material-symbols-outlined">settings</span>
                </button>
                <div class="h-8 w-8 rounded-full overflow-hidden ml-2 bg-zinc-800 ring-2 ring-primary/20">
                    <img alt="User avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBbx2Mj63NVZiPqxqMS28GCtTbGbW1CNAOkc8yJVtOAVAdOgvu-3jXui2tghL-SVwVsHhjNDRlQ3_xBRsamLPwnv5yb1sGFJR3QE8LbHdCgklBTRrh8BQr8hN1uuKC8P12vkTrRJdiCfiRA_YnpC9KVxkj4fR998NB7K6gdhUfcWWnGJ37Q9truWBu22dDEBOJJcYWlXNUyTDdsH5bdDDG4ox2iCaBA_7A683YL894k7B3vGzOVc3Tjfqptfq6VKJVW5G3pRyM0-i_e" />
                </div>
            </div>
        </header>

        <div class="p-6 space-y-8 max-w-[1600px] mx-auto w-full">
            <!-- Welcome Header -->
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div>
                    <h3 class="text-zinc-500 font-medium tracking-wide text-xs uppercase mb-1">Overview Dashboard</h3>
                    <h2 class="text-3xl font-extrabold text-white font-headline tracking-tight">System Performance</h2>
                </div>
                <div class="flex gap-2">
                    <div class="bg-surface-container flex items-center rounded-xl px-4 py-2 gap-3 cursor-pointer hover:bg-surface-container-high transition-all">
                        <span class="material-symbols-outlined text-primary text-sm">calendar_today</span>
                        <span class="text-xs font-semibold text-zinc-300">Last 30 Days</span>
                        <span class="material-symbols-outlined text-zinc-500 text-xs">expand_more</span>
                    </div>
                    <button class="bg-surface-container-high p-2 rounded-xl text-zinc-300 hover:bg-zinc-700 transition-all">
                        <span class="material-symbols-outlined text-sm">filter_list</span>
                    </button>
                </div>
            </div>

            <!-- Metrics Cards - Dinamik -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Total Revenue Kartı -->
                <div class="mt-6 flex items-center gap-2">
                    <span class="flex items-center text-secondary text-[10px] font-bold bg-secondary/10 px-2 py-0.5 rounded-full">
                        <span class="material-symbols-outlined text-[12px] mr-1">trending_up</span>
                        @(Model.RevenueGrowthRate.ToString("F1"))%
                    </span>
                    <span class="text-zinc-500 text-[10px]">vs last month</span>
                </div>

                <!-- Total Orders Kartı -->
                <div class="mt-6 flex items-center gap-2">
                    <span class="flex items-center text-secondary text-[10px] font-bold bg-secondary/10 px-2 py-0.5 rounded-full">
                        <span class="material-symbols-outlined text-[12px] mr-1">trending_up</span>
                        @(Model.OrdersGrowthRate.ToString("F1"))%
                    </span>
                    <span class="text-zinc-500 text-[10px]">vs last month</span>
                </div>

                <!-- Total Customers Kartı -->
                <div class="mt-6 flex items-center gap-2">
                    <span class="flex items-center text-secondary text-[10px] font-bold bg-secondary/10 px-2 py-0.5 rounded-full">
                        <span class="material-symbols-outlined text-[12px] mr-1">trending_up</span>
                        @(Model.CustomersGrowthRate.ToString("F1"))%
                    </span>
                    <span class="text-zinc-500 text-[10px]">active this week</span>
                </div>

                <!-- Total Customers -->
                <div class="bg-surface-container p-6 rounded-xl flex flex-col justify-between relative overflow-hidden">
                    <div class="flex items-start justify-between">
                        <div class="space-y-1">
                            <span class="text-zinc-50uyzz0 text-xs font-medium uppercase tracking-widest">Total Customers</span>
                            <div class="text-2xl font-extrabold text-white font-headline">
                                @(Model.Summary?.TotalCustomers.ToString("N0") ?? "0")
                            </div>
                        </div>
                        <div class="bg-sky-500/10 p-2 rounded-lg text-sky-400">
                            <span class="material-symbols-outlined text-xl">person</span>
                        </div>
                    </div>
                    <div class="mt-6 flex items-center gap-2">
                        <span class="flex items-center text-secondary text-[10px] font-bold bg-secondary/10 px-2 py-0.5 rounded-full">
                            <span class="material-symbols-outlined text-[12px] mr-1">trending_up</span>
                            +18.1%
                        </span>
                        <span class="text-zinc-500 text-[10px]">active this week</span>
                    </div>
                </div>

                <!-- Average Order Value -->
                <div class="bg-surface-container p-6 rounded-xl flex flex-col justify-between relative overflow-hidden">
                    <div class="flex items-start justify-between">
                        <div class="space-y-1">
                            <span class="text-zinc-500 text-xs font-medium uppercase tracking-widest">Avg Order Value</span>
                            <div class="text-2xl font-extrabold text-white font-headline">
                                @(Model.Summary?.AvgOrderValue.ToString("C2") ?? "$0.00")
                            </div>
                        </div>
                        <div class="bg-secondary/10 p-2 rounded-lg text-secondary">
                            <span class="material-symbols-outlined text-xl">inventory</span>
                        </div>
                    </div>
                    <div class="mt-6 flex items-center gap-2">
                        <span class="flex items-center text-zinc-400 text-[10px] font-bold bg-zinc-800 px-2 py-0.5 rounded-full">
                            +5.2%
                        </span>
                        <span class="text-zinc-500 text-[10px]">from last month</span>
                    </div>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <!-- Daily Sales Line Chart -->
                <div class="lg:col-span-8 bg-surface-container rounded-xl p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h4 class="text-lg font-bold text-white font-headline">Daily Sales</h4>
                            <p class="text-xs text-zinc-500">Last 30 days revenue tracking</p>
                        </div>
                        <div class="flex gap-4">
                            <div class="flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-primary"></span>
                                <span class="text-[10px] text-zinc-400 uppercase font-medium">Revenue</span>
                            </div>
                        </div>
                    </div>
                    <canvas id="dailySalesChart" height="300"></canvas>
                </div>

                <!-- Country Based Sales Pie Chart -->
                <div class="lg:col-span-4 bg-surface-container rounded-xl p-6 flex flex-col">
                    <h4 class="text-lg font-bold text-white font-headline mb-6">Revenue by Country</h4>
                    <canvas id="countrySalesChart"></canvas>
                    <div class="space-y-3 mt-6">
                        @if (Model.CountrySales != null && Model.CountrySales.Any())
                        {
                            var total = Model.CountrySales.Sum(x => x.TotalSales);
                            var colors = new[] { "#89ceff", "#4edea3", "#ffb86e", "#ffdcbd", "#c9e6ff", "#de8712", "#a78bfa" };
                            var index = 0;
                            foreach (var item in Model.CountrySales.Take(5))
                            {
                                var percentage = total > 0 ? (item.TotalSales / total * 100) : 0;
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="w-2 h-2 rounded-full" style="background-color: @colors[index % colors.Length]"></span>
                                        <span class="text-sm text-zinc-300">@item.Country</span>
                                    </div>
                                    <span class="text-sm font-bold text-white">@percentage.ToString("F1")%</span>
                                </div>
                                index++;
                            }
                        }
                        else
                        {
                            <div class="text-center text-zinc-500 py-4">No data available</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Second Row Charts -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <!-- Top Products Bar Chart -->
                <div class="lg:col-span-5 bg-surface-container rounded-xl p-6">
                    <h4 class="text-lg font-bold text-white font-headline mb-6">Top Selling Products</h4>
                    <canvas id="topProductsChart" height="300"></canvas>
                </div>

                <!-- City Based Sales Pie Chart -->
                <div class="lg:col-span-3 bg-surface-container rounded-xl p-6">
                    <h4 class="text-lg font-bold text-white font-headline mb-6">Sales by City</h4>
                    <canvas id="citySalesChart"></canvas>
                </div>

                <!-- Recent Orders Table -->
                <div class="lg:col-span-4 bg-surface-container rounded-xl overflow-hidden">
                    <div class="p-6 flex items-center justify-between">
                        <h4 class="text-lg font-bold text-white font-headline">Recent Orders</h4>
                        <button class="text-primary text-xs font-bold hover:underline">View All</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="bg-surface-container-low text-[10px] uppercase tracking-widest text-zinc-500">
                                    <th class="px-6 py-3 font-semibold">Order ID</th>
                                    <th class="px-6 py-3 font-semibold">Customer</th>
                                    <th class="px-6 py-3 font-semibold">Amount</th>
                                    <th class="px-6 py-3 font-semibold">Date</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                @if (Model.LastOrders != null && Model.LastOrders.Any())
                                {
                                    foreach (var order in Model.LastOrders.Take(5))
                                    {
                                        <tr class="hover:bg-surface-container-highest transition-colors cursor-pointer group">
                                            <td class="px-6 py-4 text-xs font-mono text-zinc-400">#@order.OrderId</td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-7 h-7 rounded-full bg-zinc-800 flex items-center justify-center text-[10px] text-primary">
                                                        @(order.CustomerName?.Split(' ').Select(s => s[0]).Aggregate("", (a, b) => a + b) ?? "??")
                                                    </div>
                                                    <span class="text-sm text-zinc-200">@order.CustomerName</span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-sm font-bold text-white">@order.TotalAmount.ToString("C2")</td>
                                            <td class="px-6 py-4 text-xs text-zinc-500">@order.OrderDate.ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="px-6 py-8 text-center text-zinc-500">No recent orders found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

     
            <!-- Sales by Category Section - Dinamik -->
            <div class="bg-surface-container rounded-xl p-6">
                <h4 class="text-lg font-bold text-white font-headline mb-6">Sales by Category</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-6">
                    @if (Model.CategorySales != null && Model.CategorySales.Any())
                    {
                        var colors = new[] { "primary", "secondary", "tertiary", "sky-400", "emerald-400", "amber-400" };
                        var index = 0;
                        foreach (var category in Model.CategorySales.Take(6))
                        {
                            var colorClass = colors[index % colors.Length];
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-surface-container-highest flex items-center justify-center text-@colorClass">
                                    <span class="material-symbols-outlined">@category.Icon</span>
                                </div>
                                <div class="flex-1">
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-zinc-300">@category.CategoryName</span>
                                        <span class="font-bold text-white">@category.TotalSales.ToString("C0")</span>
                                    </div>
                                    <div class="w-full h-2 bg-zinc-800 rounded-full">
                                        <div class="h-full bg-@colorClass rounded-full" style="width: @category.Percentage%"></div>
                                    </div>
                                </div>
                            </div>
                            index++;
                        }
                    }
                    else
                    {
                        <div class="col-span-full text-center text-zinc-500 py-8">No category data available</div>
                    }
                </div>
            </div>

            <!-- Footer -->
            <footer class="border-t border-white/5 bg-surface-container mt-4">
                <div class="p-6 flex flex-col md:flex-row items-center justify-between gap-6 opacity-80">
                    <div class="flex items-center gap-8">
                        <div>
                            <span class="text-[10px] uppercase text-zinc-500 font-bold block mb-1">Avg Order Value</span>
                            <span class="text-lg font-bold text-white font-headline">@(Model.Summary?.AvgOrderValue.ToString("C2") ?? "$0.00")</span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-zinc-500 font-bold block mb-1">Return Rate</span>
                            <span class="text-lg font-bold text-error font-headline">2.1%</span>
                        </div>
                        <div>
                            <span class="text-[10px] uppercase text-zinc-500 font-bold block mb-1">Store Sessions</span>
                            <span class="text-lg font-bold text-secondary font-headline">48.2K</span>
                        </div>
                    </div>
                    <p class="text-[10px] text-zinc-600 font-medium">© 2024 Luminous Archive. Data refreshed every 60 seconds.</p>
                </div>
            </footer>
        </div>
    </main>

    <!-- Floating Action Button for Mobile -->
    <button class="md:hidden fixed bottom-6 right-6 w-14 h-14 bg-primary text-on-primary rounded-full shadow-2xl flex items-center justify-center z-50">
        <span class="material-symbols-outlined">add</span>
    </button>

    <!-- Chart.js Scripts -->
    <script>
        (function() {
            // Daily Sales Line Chart
            const dailySalesData = @Html.Raw(Json.Serialize(Model.DailySales ?? new List<ECommerceBigData.Dtos.DailySalesDto>()));
            const dailySalesCtx = document.getElementById('dailySalesChart')?.getContext('2d');
            if (dailySalesCtx && dailySalesData.length > 0) {
                new Chart(dailySalesCtx, {
                    type: 'line',
                    data: {
                        labels: dailySalesData.map(x => {
                            const date = new Date(x.Date);
                            return date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' });
                        }),
                        datasets: [{
                            label: 'Sales',
                            data: dailySalesData.map(x => x.TotalSales),
                            borderColor: '#89ceff',
                            backgroundColor: 'rgba(137, 206, 255, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.3,
                            pointBackgroundColor: '#89ceff',
                            pointBorderColor: '#131313',
                            pointRadius: 3,
                            pointHoverRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                callbacks: {
                                    label: (ctx) => `$${ctx.raw.toLocaleString()}`
                                }
                            }
                        },
                        scales: {
                            y: {
                                grid: { color: 'rgba(255,255,255,0.05)' },
                                ticks: {
                                    color: '#888',
                                    callback: (value) => `$${value.toLocaleString()}`
                                }
                            },
                            x: { grid: { display: false }, ticks: { color: '#888' } }
                        }
                    }
                });
            }

            // Country Sales Pie Chart
            const countrySalesData = @Html.Raw(Json.Serialize(Model.CountrySales ?? new List<ECommerceBigData.Dtos.CountrySalesDto>()));
            const countrySalesCtx = document.getElementById('countrySalesChart')?.getContext('2d');
            if (countrySalesCtx && countrySalesData.length > 0) {
                const colors = ['#89ceff', '#4edea3', '#ffb86e', '#ffdcbd', '#c9e6ff', '#de8712', '#a78bfa'];
                new Chart(countrySalesCtx, {
                    type: 'pie',
                    data: {
                        labels: countrySalesData.map(x => x.Country),
                        datasets: [{
                            data: countrySalesData.map(x => x.TotalSales),
                            backgroundColor: colors.slice(0, countrySalesData.length),
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: '#888', font: { size: 10 } }
                            },
                            tooltip: {
                                callbacks: {
                                    label: (ctx) => {
                                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = ((ctx.raw / total) * 100).toFixed(1);
                                        return `${ctx.label}: $${ctx.raw.toLocaleString()} (${percentage}%)`;
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // Top Products Bar Chart
            const topProductsData = @Html.Raw(Json.Serialize(Model.TopProducts ?? new List<ECommerceBigData.Dtos.TopProductDto>()));
            const topProductsCtx = document.getElementById('topProductsChart')?.getContext('2d');
            if (topProductsCtx && topProductsData.length > 0) {
                new Chart(topProductsCtx, {
                    type: 'bar',
                    data: {
                               labels: topProductsData.map(x => {
            const name = x.ProductName || "Unknown";

            return name.length > 20
                ? name.substring(0, 18) + "..."
                : name;
        }),
                        datasets: [{
                            label: 'Units Sold',
                            data: topProductsData.map(x => x.TotalQuantity),
                            backgroundColor: '#89ceff',
                            borderRadius: 8,
                            barPercentage: 0.7
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: (ctx) => `${ctx.raw} units sold`
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(255,255,255,0.05)' },
                                ticks: { color: '#888' }
                            },
                            x: {
                                ticks: { color: '#888', font: { size: 10 } }
                            }
                        }
                    }
                });
            }

            // City Sales Pie Chart
            const citySalesData = @Html.Raw(Json.Serialize(Model.CitySales ?? new List<ECommerceBigData.Dtos.CitySalesDto>()));
            const citySalesCtx = document.getElementById('citySalesChart')?.getContext('2d');
            if (citySalesCtx && citySalesData.length > 0) {
                const colors = ['#89ceff', '#4edea3', '#ffb86e', '#ffdcbd', '#c9e6ff', '#de8712', '#a78bfa'];
                new Chart(citySalesCtx, {
                    type: 'pie',
                    data: {
                        labels: citySalesData.map(x => x.City),
                        datasets: [{
                            data: citySalesData.map(x => x.TotalSales),
                            backgroundColor: colors.slice(0, citySalesData.length),
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: '#888', font: { size: 10 } }
                            },
                            tooltip: {
                                callbacks: {
                                    label: (ctx) => {
                                        const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = ((ctx.raw / total) * 100).toFixed(1);
                                        return `${ctx.label}: $${ctx.raw.toLocaleString()} (${percentage}%)`;
                                    }
                                }
                            }
                        }
                    }
                });
            } else if (citySalesCtx) {
                // No data placeholder
                citySalesCtx.canvas.parentElement.innerHTML = '<div class="flex items-center justify-center h-48 text-zinc-500">No city data available</div>';
            }
        })();
    </script>
</body>
</html>