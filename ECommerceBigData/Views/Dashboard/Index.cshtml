@model ECommerceBigData.Models.DashboardViewModel
@{
    
    ViewData["Title"] = "Genel Bakış";
    Layout = "_DashboardLayout";
}


<div class="dashboard-page">
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h3 class="text-zinc-500 text-xs uppercase tracking-widest">Gösterge Paneli</h3>
            <h2 class="text-3xl font-extrabold tracking-tight">Sistem Performansı V4</h2>
        </div>
        <div class="chip px-3 py-2 text-xs text-zinc-400">
            Veri Aralığı: @Model.Filters.EffectiveFrom.ToString("d") - @Model.Filters.EffectiveTo.ToString("d")
        </div>
    </header>


    @await Html.PartialAsync("Partials/_FilterBar", Model)
    @await Html.PartialAsync("Partials/_KpiCards", Model)
    @await Html.PartialAsync("Partials/_PrimaryCharts", Model)
    @await Html.PartialAsync("Partials/_AdvancedAnalytics", Model)
    @await Html.PartialAsync("Partials/_SearchAndTables", Model)
</div>

       
       
@section Scripts {
<script>
    window.dashboardData = {
        dailySales: @Html.Raw(Json.Serialize(Model.DailySales)),
        countrySales: @Html.Raw(Json.Serialize(Model.CountrySales)),
        citySales: @Html.Raw(Json.Serialize(Model.CitySales)),
        topProducts: @Html.Raw(Json.Serialize(Model.TopProducts)),
        monthlyRevenue: @Html.Raw(Json.Serialize(Model.MonthlyRevenue)),
        hourlyHeatmap: @Html.Raw(Json.Serialize(Model.HourlyHeatmap)),
        segmentDistribution: @Html.Raw(Json.Serialize(Model.SegmentDistribution))
    };
</script>
<script src="~/js/dashboard/charts.js" asp-append-version="true"></script>
<script src="~/js/dashboard/search.js" asp-append-version="true"></script>
}