@model ECommerceBigData.Models.DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Archive Admin | Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
   
    <style>
        
        body { background-color: #131313; color: #e5e2e1; font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .panel { background: rgba(32,31,31,.88); border: 1px solid rgba(255,255,255,.05); border-radius: .75rem; }
        .chip { border: 1px solid rgba(255,255,255,.1); border-radius: .75rem; }
        .heat-cell { min-height: 20px; border-radius: 4px; }
    </style>
</head>

<body>
    <main class="max-w-[1700px] mx-auto px-6 py-6 space-y-6">
        <header class="flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h3 class="text-zinc-500 text-xs uppercase tracking-widest">Overview Dashboard</h3>
                <h1 class="text-3xl font-extrabold tracking-tight">System Performance v4</h1>
            </div>
           
            <div class="chip px-3 py-2 text-xs text-zinc-400">
                Veri Aralığı: @Model.Filters.EffectiveFrom.ToString("dd.MM.yyyy") - @Model.Filters.EffectiveTo.ToString("dd.MM.yyyy")
            </div>
        </header>

       
        @await Html.PartialAsync("Partials/_FilterBar", Model)
        @await Html.PartialAsync("Partials/_KpiCards", Model)
        @await Html.PartialAsync("Partials/_PrimaryCharts", Model)
        @await Html.PartialAsync("Partials/_AdvancedAnalytics", Model)
        @await Html.PartialAsync("Partials/_SearchAndTables", Model)
    </main>

 
    <script>
       
        window.dashboardData = {
            dailySales: @Html.Raw(Json.Serialize(Model.DailySales)),
            countrySales: @Html.Raw(Json.Serialize(Model.CountrySales)),
            citySales: @Html.Raw(Json.Serialize(Model.CitySales)),
            topProducts: @Html.Raw(Json.Serialize(Model.TopProducts)),
            monthlyRevenue: @Html.Raw(Json.Serialize(Model.MonthlyRevenue)),
            hourlyHeatmap: @Html.Raw(Json.Serialize(Model.HourlyHeatmap)),
            segmentDistribution: @Html.Raw(Json.Serialize(Model.SegmentDistribution))
        };
    </script>
    <script src="~/js/dashboard/charts.js" asp-append-version="true"></script>
    <script src="~/js/dashboard/search.js" asp-append-version="true"></script>
</body>

</html>